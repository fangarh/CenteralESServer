# Copy to .env for local Docker Compose runs. Do not commit .env.

CENTERALES_POSTGRES_DB=centerales
CENTERALES_POSTGRES_USER=centerales
CENTERALES_POSTGRES_PASSWORD=change_me_for_local_compose

# Local demo default. For real pdf2txt processing set:
# CENTERALES_PDF_RECOGNIZER=Http
# CENTERALES_PDF2TXT_ENDPOINT=https://your-pdf2txt-host/recognize_json/
CENTERALES_PDF_RECOGNIZER=Fake
CENTERALES_PDF2TXT_ENDPOINT=

CENTERALES_WEB_PORT=8080
CENTERALES_ALLOWED_HOSTS=localhost;127.0.0.1
