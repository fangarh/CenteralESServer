{
  "Database": {
    "AutoBootstrap": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "PdfStampRecognition": {
    "Recognizer": "Http",
    "Processor": {
      "endpointPool": [],
      "poolConcurrencyLimit": 4,
      "endpointConcurrencyLimit": 2,
      "timeout": "00:00:30",
      "maxAttempts": 5,
      "processorOverloadedDelay": "00:00:15"
    },
    "Recovery": {
      "enabled": true,
      "staleJobTimeout": "00:05:00",
      "recoveryInterval": "00:01:00",
      "batchSize": 50
    }
  }
}
